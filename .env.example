# ============================================================================
# 环境变量配置示例文件
# Environment Variables Configuration Example
# ============================================================================
#
# 使用说明 / Usage:
# 1. 复制此文件为 .env: cp .env.example .env
#    Copy this file to .env: cp .env.example .env
# 2. 将下面的占位符替换为你的真实 API Key
#    Replace the placeholders below with your actual API keys
# 3. 注意：.env 文件已添加到 .gitignore，不会被提交到版本库
#    Note: .env file is in .gitignore and will not be committed to the repository
#
# ============================================================================

# 阿里云 DashScope API Key（推荐使用）
# Alibaba Cloud DashScope API Key (Recommended)
# 获取方式：登录阿里云控制台 -> 开通 DashScope 服务 -> 创建 API Key
# How to get: Login to Alibaba Cloud Console -> Enable DashScope Service -> Create API Key
# 文档：https://help.aliyun.com/zh/dashscope/developer-reference/activate-dashscope-and-create-an-api-key
#DASHSCOPE_API_KEY=your_dashscope_api_key_here
#DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 通用 API Key（兼容性选项，如果设置了 DASHSCOPE_API_KEY，此项可选）
# Generic API Key (Compatibility option, optional if DASHSCOPE_API_KEY is set)
# 如果使用阿里云 DashScope，可以设置为与 DASHSCOPE_API_KEY 相同的值
# If using Alibaba Cloud DashScope, you can set this to the same value as DASHSCOPE_API_KEY
API_KEY=your_api_key_here

# ============================================================================
# 可选配置 / Optional Configuration
# ============================================================================

# OpenAI API Key（如果使用 OpenAI 服务）
# OpenAI API Key (if using OpenAI service)
# OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Base URL（如果使用兼容 OpenAI 格式的其他服务）
# OpenAI Base URL (if using other services compatible with OpenAI format)
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
